{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/"}},"html":"<!DOCTYPE html><!--A3LeUCOwRfRkXmikxpg6N--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/db4a602155f01524.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-4e6bf084ac60582b.js\"/><script src=\"/_next/static/chunks/4bd1b696-c023c6e3521b1417.js\" async=\"\"></script><script src=\"/_next/static/chunks/255-e3bf15caf1f1e0f9.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-5aae37068019f50e.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/page-d7242514a86d1068.js\" async=\"\"></script><title>AI Product Content Generator</title><meta name=\"description\" content=\"Generate high-converting Amazon listings in seconds\"/><link rel=\"icon\" href=\"/favicon.ico\" type=\"image/x-icon\" sizes=\"16x16\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen bg-gradient-to-br from-slate-50 to-blue-50\"><div class=\"max-w-4xl mx-auto px-4 py-12\"><div class=\"text-center mb-12\"><h1 class=\"text-4xl font-bold text-slate-900 mb-3\">AI Product Content Generator</h1><p class=\"text-lg text-slate-600\">Generate high-converting Amazon listings in seconds</p></div><div class=\"grid md:grid-cols-2 gap-8\"><div class=\"bg-white rounded-2xl shadow-lg p-6\"><h2 class=\"text-xl font-semibold text-slate-800 mb-6\">Product Information</h2><form class=\"space-y-4\"><div><label class=\"block text-sm font-medium text-slate-700 mb-1\">Product Name *</label><input type=\"text\" required=\"\" placeholder=\"Men&#x27;s Ice Silk Underwear\" class=\"w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition\" name=\"productName\" value=\"\"/></div><div><label class=\"block text-sm font-medium text-slate-700 mb-1\">Brand Name</label><input type=\"text\" placeholder=\"CozyFit\" class=\"w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition\" name=\"brandName\" value=\"\"/></div><div><label class=\"block text-sm font-medium text-slate-700 mb-1\">Key Features * <span class=\"text-slate-400 text-xs\">(comma separated)</span></label><textarea name=\"features\" required=\"\" rows=\"3\" placeholder=\"breathable, cooling, seamless\" class=\"w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition resize-none\"></textarea></div><div><label class=\"block text-sm font-medium text-slate-700 mb-1\">Target Audience</label><input type=\"text\" placeholder=\"men, athletes\" class=\"w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition\" name=\"audience\" value=\"\"/></div><div><label class=\"block text-sm font-medium text-slate-700 mb-1\">Core Keywords <span class=\"text-slate-400 text-xs\">(for SEO)</span></label><input type=\"text\" placeholder=\"ice silk underwear, mens underwear\" class=\"w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition\" name=\"keywords\" value=\"\"/></div><div class=\"grid grid-cols-2 gap-4\"><div><label class=\"block text-sm font-medium text-slate-700 mb-1\">Tone</label><select name=\"tone\" class=\"w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition\"><option value=\"professional\">Professional</option><option value=\"persuasive\" selected=\"\">Persuasive</option><option value=\"friendly\">Friendly</option><option value=\"luxury\">Luxury</option></select></div><div><label class=\"block text-sm font-medium text-slate-700 mb-1\">Platform</label><select name=\"platform\" class=\"w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition\"><option value=\"amazon\" selected=\"\">Amazon</option><option value=\"shopify\" disabled=\"\">Shopify (Coming Soon)</option></select></div></div><button type=\"submit\" class=\"w-full bg-blue-600 hover:bg-blue-700 disabled:bg-blue-400 text-white font-semibold py-3 px-6 rounded-lg transition duration-200 flex items-center justify-center gap-2\">✨ Generate Listing</button></form></div><div class=\"bg-white rounded-2xl shadow-lg p-6\"><div class=\"flex items-center justify-between mb-6\"><h2 class=\"text-xl font-semibold text-slate-800\">Generated Content</h2></div><div class=\"h-full flex items-center justify-center text-slate-400\"><div class=\"text-center\"><div class=\"text-4xl mb-2\">📝</div><p>Fill in the form and click generate</p></div></div></div></div><div class=\"mt-12 text-center text-sm text-slate-500\"><p>Free tier: 10 generations per day</p></div></div></div><!--$--><!--/$--><script src=\"/_next/static/chunks/webpack-4e6bf084ac60582b.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[9766,[],\\\"\\\"]\\n3:I[8924,[],\\\"\\\"]\\n4:I[1959,[],\\\"ClientPageRoot\\\"]\\n5:I[9547,[\\\"974\\\",\\\"static/chunks/app/page-d7242514a86d1068.js\\\"],\\\"default\\\"]\\n8:I[4431,[],\\\"OutletBoundary\\\"]\\na:I[5278,[],\\\"AsyncMetadataOutlet\\\"]\\nc:I[4431,[],\\\"ViewportBoundary\\\"]\\ne:I[4431,[],\\\"MetadataBoundary\\\"]\\nf:\\\"$Sreact.suspense\\\"\\n11:I[7150,[],\\\"\\\"]\\n:HL[\\\"/_next/static/css/db4a602155f01524.css\\\",\\\"style\\\"]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"b\\\":\\\"A3LeUCOwRfRkXmikxpg6N\\\",\